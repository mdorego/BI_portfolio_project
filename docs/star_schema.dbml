// ============================================================
// Star Schema for BI Portfolio
//
// Central Fact Table: fact_sessions
// Dimension Tables: dim_date, dim_channel, dim_page, dim_competitor
//
// Generated from transform/sql/marts/ SQL definitions
// ============================================================

// Fact Table: Sessions
Table fact_sessions {
  session_id VARCHAR [primary key, not null]
  user_pseudo_id VARCHAR [not null]
  ga_session_id VARCHAR [not null]
  session_date DATE [not null]
  date_id DATE [not null]
  channel VARCHAR [not null]
  source VARCHAR [not null]
  channel_group VARCHAR
  device_category VARCHAR
  country VARCHAR
  page_path VARCHAR
  page_category VARCHAR
  organic_position INT
  has_seo_data BOOLEAN
  landing_page_path VARCHAR
  engaged_session BOOLEAN
  session_duration_sec INT
  page_views INT
  purchases INT
  revenue FLOAT64

  indexes {
    (channel, source) [type: composite]
    date_id
    page_path
  }
}

// Dimension Table: Date
Table dim_date {
  date_id DATE [primary key, not null]
  year INT
  month INT
  month_name VARCHAR
  week_of_year INT
  day_of_week INT
  day_name VARCHAR
  is_weekend BOOLEAN
}

// Dimension Table: Channel
Table dim_channel {
  channel VARCHAR [not null, pk]
  source VARCHAR [not null, pk]
  channel_group VARCHAR
}

// Dimension Table: Page
Table dim_page {
  page_path VARCHAR [primary key, not null]
  page_category VARCHAR
  top_keyword VARCHAR
  organic_position INT
  search_volume INT
  has_seo_data BOOLEAN
}

// Dimension Table: Competitor
Table dim_competitor {
  domain VARCHAR [primary key, not null]
  semrush_rank INT
  organic_keywords INT
  organic_traffic FLOAT64
  organic_cost FLOAT64
  paid_keywords INT
  is_target BOOLEAN
}

// ============================================================
// RELATIONSHIPS
// ============================================================

// Sessions to Date Dimension
Ref fact_sessions_date: fact_sessions.date_id > dim_date.date_id

// Sessions to Channel Dimension (composite key)
Ref fact_sessions_channel: fact_sessions.(channel, source) > dim_channel.(channel, source)

// Sessions to Page Dimension
Ref fact_sessions_page: fact_sessions.page_path > dim_page.page_path
