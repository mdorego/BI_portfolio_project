# GCP Configuration
GCP_PROJECT=bi-portfolio-project

# BigQuery Datasets
BQ_STAGING_DATASET=staging
BQ_MARTS_DATASET=marts
BQ_REPORTING_DATASET=reporting

# SEMrush API (if running ingestion/semrush_api_pull.py)
# SEMRUSH_API_KEY=your_api_key_here

# Optional: Data paths (defaults to ./data/raw and ./data/prepared)
# RAW_DATA_DIR=./data/raw
# PREPARED_DATA_DIR=./data/prepared
